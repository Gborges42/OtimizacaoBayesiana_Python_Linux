!================================================================================================================================
! Configuracoes Gerais das simulacoes
! Paralelismo (desliga no primeiro teste)
paralelo = FALSE
cores = 1

! Metodo de score (rmse ou mape)
metodo_score = mape

! Fator k de escolha Bayesiana
iters.k = 1
!================================================================================================================================

!================================================================================================================================
! Parametros da Otimizacao Bayesiana(bem pequeno para teste)
! Um para cada simulacao (Manter mesmo numero de valores)
! Pontos Iniciais
initPoints = 100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200,100,100,200

