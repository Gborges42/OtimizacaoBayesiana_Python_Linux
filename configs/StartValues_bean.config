!================================================================================================================================
! Mapeamento de pastas de entrada e saida
! Diretorio do experimento
dirExperiment = ./Baseline/Bean

! Executavel do DSSAT (Linux)
dssatFile = ./bin/dscsm047

! Arquivo de cultivares
cultivarFile = ./Baseline/Bean/BNGRO047.CUL

! Diretorio de saida (resultados e logs)
outputDir = ./output

! Diretorio dos Arquivos BNX
bnxDir = ./Baseline/Config_BNX
!================================================================================================================================

!================================================================================================================================
! Fator de aleatoriedade da simulacao
! Semente (0 => aleatoria; outro valor => reproduzivel)
seed = 123
!================================================================================================================================

!================================================================================================================================
! Arquivos de modelos para simulacao
! Identificador do cultivar
cultivar = IB0096

! Identificador do modelo
model = CRGRO047
!================================================================================================================================

!================================================================================================================================
! Coeficientes a calibrar (use poucos no primeiro teste)
! Fenologia (EM-FL, FL-SH, FL-SD, SD-PM, FL-LF)
! Crescimento (LFMAX, SLAVR, SIZLF, WTPSD, SFDUR, SDPDV, PODUR, THRSH)
coefficients = EM-FL, FL-SH, FL-SD, SD-PM, FL-LF, LFMAX, SLAVR, SIZLF, WTPSD, SFDUR, SDPDV, PODUR, THRSH

! Limites dos coeficientes (mesma ordem/nome)
limites = EM-FL:20;35, FL-SH:2;5, FL-SD:6;13, SD-PM:14;29, FL-LF:10;34, LFMAX:0.98;1.00, SLAVR:250;350, SIZLF:133;180, WTPSD:0.22;0.66, SFDUR:11;22, SDPDV:3;5, PODUR:4;16, THRSH:78.0;78.00

! Variaveis de calibracao (use 1 no primeiro teste)
! Fenologia (ADAP, PD1P, PDFP, MDAP)
! Crescimento (HWAM, PWAM, HWUM, H#AM, H#UM, THAM, LAIX, HIAM)
calibration = ADAP, PD1P, PDFP, MDAP, HWAM, PWAM, HWUM, H#AM, H#UM, THAM, LAIX, HIAM



!================================================================================================================================
